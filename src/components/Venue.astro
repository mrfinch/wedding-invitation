---
// Replace with real venue details
const venue = {
  name: "TBD",
  subtitle: "Ahmedabad, Gujarat",
  address: "Address to be updated",
  city: "Ahmedabad, Gujarat",
  mapsQuery: "Ahmedabad+Gujarat",
  // Paste a real Google Maps embed src URL here
  mapsEmbedSrc: `https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d235013.9!2d72.4346!3d23.0225!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x395e848aba5bd449%3A0x4fcedd11614f6516!2sAhmedabad%2C%20Gujarat!5e0!3m2!1sen!2sin!4v1700000000000`,
  directions: "More details on travel and parking will be shared closer to the date.",
};
---

<section id="venue" class="py-24 px-6" style="background: #f0faf8;">
  <div class="max-w-3xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-14">
      <p class="section-eyebrow">Where to Find Us</p>
      <h2 class="section-title">Venue</h2>
      <div class="section-rule"></div>
    </div>

    <div class="venue-grid">
      <!-- Address card -->
      <div class="venue-info">
        <h3 class="venue-name">{venue.name}</h3>
        <p class="venue-subtitle">{venue.subtitle}</p>

        <div class="venue-address">
          <p>{venue.address}</p>
          <p>{venue.city}</p>
        </div>

        <p class="venue-directions">{venue.directions}</p>

        <a
          href={`https://www.google.com/maps/search/${venue.mapsQuery}`}
          target="_blank"
          rel="noopener noreferrer"
          class="directions-btn"
        >
          Get Directions &rarr;
        </a>
      </div>

      <!-- Map embed -->
      <div class="map-wrapper">
        <iframe
          title="Venue map"
          src={venue.mapsEmbedSrc}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .section-eyebrow {
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #3d8b85;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 300;
    color: #1a3a36;
  }

  .section-rule {
    width: 48px;
    height: 1px;
    background: #3d8b85;
    margin: 1.25rem auto 0;
  }

  .venue-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 640px) {
    .venue-grid {
      grid-template-columns: 1fr;
    }
  }

  .venue-info {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .venue-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 400;
    color: #1a3a36;
    line-height: 1.2;
  }

  .venue-subtitle {
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: #3d8b85;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
    margin-bottom: 1.25rem;
  }

  .venue-address {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: #456b66;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .venue-directions {
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: #89bab5;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .directions-btn {
    display: inline-block;
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #3d8b85;
    border: 1px solid #3d8b85;
    padding: 0.6rem 1.4rem;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .directions-btn:hover {
    background: #3d8b85;
    color: #fff;
  }

  .map-wrapper {
    height: 320px;
    border: 1px solid #c8e8e4;
    overflow: hidden;
  }
</style>
